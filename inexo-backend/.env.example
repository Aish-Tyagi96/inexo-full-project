NODE_ENV=development
APP_NAME=Inexo Backend
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=*
LOG_LEVEL=info
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=1d
DB_DIALECT=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inexo_backend
DB_USER=root
DB_PASSWORD=
DB_STORAGE=.data/inexo.sqlite
DB_SYNC_ALTER=false
DB_SYNC_FORCE=false
SEED_DEFAULT_ADMIN=true
DEFAULT_ADMIN_NAME=Primary Admin
DEFAULT_ADMIN_EMAIL=admin@inexo.com
DEFAULT_ADMIN_PHONE=1234567890
DEFAULT_ADMIN_PASSWORD=Admin@12345
DEFAULT_ROLES=Admin
